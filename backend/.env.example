# Server
PORT=8787

# Database: file | postgres
DB_PROVIDER=file
DATABASE_URL=

# JWT (change in production)
JWT_SECRET=replace-me-with-a-long-random-string
JWT_TTL_DAYS=14
ADMIN_SECRET=replace-me-with-a-different-long-random-string
CORS_ORIGINS=http://localhost:5173

# LLM provider: gemini | mock
LLM_PROVIDER=mock
LLM_MODEL=gemini-3-flash
LLM_API_KEY=
LLM_BASE_URL=
LLM_BUDGET_MAX_CALLS_PER_RUN=200

# Email provider: console | resend
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM="Campus Ditto <noreply@campusditto.hk>"

# Auth
AUTH_CODE_TTL_MIN=10
AUTH_CODE_RATE_LIMIT_PER_HOUR=5
INVITE_REQUIRED=true
